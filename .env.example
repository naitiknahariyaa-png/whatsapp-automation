# WhatsApp AI Bot v3.8 - Environment Variables
# ======================================================

# ═══════════════════════════════════════════════════════════════
# FREE AI PROVIDERS (Based on: github.com/Moh4696/build-ai-agents-free)
# ═══════════════════════════════════════════════════════════════

# Groq (RECOMMENDED - ~300 tokens/sec, 14,400 requests/day FREE)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Google Gemini (Fallback - 1,500 requests/day FREE)
# Get key: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenRouter (100+ models, some FREE) - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# OmniRoute AI Gateway (250+ providers, 90+ FREE) - https://omniroute.onl
# Install: npm install -g omniroute
OMNIROUTE_URL=http://localhost:20128
OMNIROUTE_API_KEY=

# Bot Configuration
BOT_NAME=WhatsApp AI Bot
VERSION=3.8.0
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Database
DATABASE_URL=data/whatsapp.db

# WhatsApp Session
WHATSAPP_SESSION_DIR=data/session

# ═══════════════════════════════════════════════════════════════
# OpenWA - Alternative WhatsApp API Gateway
# Based on: https://github.com/rmyndharis/OpenWA
# Features: REST API, Multi-session, Webhooks, Dashboard
# ═══════════════════════════════════════════════════════════════
# Run: docker compose -f docker-compose.dev.yml up -d
OPENWA_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=default

# Telegram Alerts (Optional - for auto-recovery notifications)
# 1. Create a bot via @BotFather and get the token
# 2. Message your bot once, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Copy your chat_id from the JSON response
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# v3.8 Tab - Telegram Bot PRO Edition
# Based on: https://github.com/rmyndharis/OpenWA
# ═══════════════════════════════════════════════════════════════
# Get your Telegram User ID: Message @userinfobot on Telegram
# Separate multiple admin IDs with commas
TELEGRAM_ADMIN_IDS=123456789

# Watchdog Settings (for auto-recovery)
HEALTH_CHECK_URL=http://localhost:8000/health
SYSTEMD_SERVICE_NAME=whatsapp-bot

# Business Information
BUSINESS_NAME=My Business
BUSINESS_PHONE=
BUSINESS_WHATSAPP=
BUSINESS_EMAIL=
BUSINESS_ADDRESS=
BUSINESS_WEBSITE=

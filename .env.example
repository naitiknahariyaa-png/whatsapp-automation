# WhatsApp Hub - Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# Telegram Bot (Required for Telegram control)
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===========================================
# AI Providers (At least one recommended)
# ===========================================
# Groq - Free tier available (Recommended)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter - Multiple AI models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini - Free tier available
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# WhatsApp Integration
# ===========================================
# WAHA or OpenWA API
OPENWA_URL=http://waha:3000
OPENWA_API_KEY=your_openwa_api_key_here
WAHA_SESSION=default

# ===========================================
# Security Settings
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
MAX_BROADCAST_RECIPIENTS=100

# ===========================================
# Optional Services
# ===========================================
# Redis Cache
REDIS_URL=redis://redis:6379

# Database
DATABASE_PATH=data/bot_database.json

# Web Dashboard
DASHBOARD_PORT=8000

# WhatsApp AI Bot v3.0 - Environment Variables
# ======================================================

# AI Provider API Keys (Get these from respective websites)

# OpenRouter (FREE AI Models) - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Groq (Fast AI) - https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Bot Configuration
BOT_NAME=WhatsApp AI Bot
VERSION=3.0.0
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Database
DATABASE_URL=data/whatsapp.db

# WhatsApp Session
WHATSAPP_SESSION_DIR=data/session

# Business Information
BUSINESS_NAME=My Business
BUSINESS_PHONE=
BUSINESS_WHATSAPP=
BUSINESS_EMAIL=
BUSINESS_ADDRESS=
BUSINESS_WEBSITE=

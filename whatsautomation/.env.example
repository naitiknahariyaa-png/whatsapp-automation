# WhatsAutomation API - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# API Configuration
PORT=8000

# ═══════════════════════════════════════════════════════════════
# FREE AI PROVIDERS
# ═══════════════════════════════════════════════════════════════

# Groq (Recommended - Fast & Free)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (100+ free models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama (Local - 100% Free)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# HuggingFace
HUGGINGFACE_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# WHATSAPP GATEWAY (OpenWA)
# ═══════════════════════════════════════════════════════════════

OPENWA_URL=http://localhost:3000
OPENWA_API_KEY=
OPENWA_SESSION_ID=default

# ═══════════════════════════════════════════════════════════════
# DATABASE (Optional)
# ═══════════════════════════════════════════════════════════════

# Supabase (PostgreSQL)
SUPABASE_URL=
SUPABASE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB
MONGODB_URI=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS (All Free)
# ═══════════════════════════════════════════════════════════════

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook
DISCORD_WEBHOOK=

# Ntfy
NTFY_URL=https://ntfy.sh

# ═══════════════════════════════════════════════════════════════
# CRM & PRODUCTIVITY (Free tier)
# ═══════════════════════════════════════════════════════════════

# Notion
NOTION_API_KEY=

# Linear
LINEAR_API_KEY=

# Cal.com
CAL_API_KEY=

# Google Calendar
GOOGLE_CREDENTIALS_PATH=./google_credentials.json

# ═══════════════════════════════════════════════════════════════
# ANALYTICS (Free tier)
# ═══════════════════════════════════════════════════════════════

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Sentry
SENTRY_DSN=

# Plausible
PLAUSIBLE_URL=

# ═══════════════════════════════════════════════════════════════
# SEARCH (Free)
# ═══════════════════════════════════════════════════════════════

MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ═══════════════════════════════════════════════════════════════
# STORAGE (Free tier)
# ═══════════════════════════════════════════════════════════════

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════
# AUTOMATION (Self-hosted - Free)
# ═══════════════════════════════════════════════════════════════

N8N_WEBHOOK_URL=
ACTIVPIECES_URL=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# CHATBOTS (Free tiers)
# ═══════════════════════════════════════════════════════════════

BOTPRESS_URL=
BOTPRESS_API_KEY=

TYPEBOT_URL=
TYPEBOT_PUBLIC_ID=

CHATWOOT_URL=
CHATWOOT_API_KEY=
